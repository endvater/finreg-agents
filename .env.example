# FinRegAgents example environment
# Copy to .env and set only the providers you actually use.

# LLM provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Gemini:
# - GEMINI_API_KEY ist der primäre Key in FinRegAgents.
# - GOOGLE_API_KEY wird als Alias unterstützt (Legacy/SDK-Kompatibilität).
GEMINI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
XAI_API_KEY=

# Optional local/remote Ollama endpoint
OLLAMA_HOST=http://localhost:11434
